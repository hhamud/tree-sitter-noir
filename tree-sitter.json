{
  "grammars": [
    {
      "name": "noir",
      "camelcase": "Noir",
      "scope": "source.noir",
      "path": ".",
      "file-types": [
        "nr"
      ],
      "injection-regex": "^noir$"
    }
  ],
  "metadata": {
    "version": "1.0.1",
    "license": "MIT",
    "description": "Noir grammar for tree-sitter",
    "authors": [
      {
        "name": "Hamza Hamud"
      }
    ],
    "links": {
      "repository": "git+https://github.com/hhamud/tree-sitter-noir.git"
    }
  },
  "bindings": {
    "c": true,
    "node": true,
    "rust": true
  }
}
