{
  "name": "tree-sitter-noir",
  "version": "1.0.1",
  "description": "tree-sitter plugin for noir language",
  "main": "bindings/node",
  "keywords": [
    "parser",
    "noir"
  ],
  "repository": "https://github.com/hhamud/tree-sitter-noir.git",
  "author": "Hamza Hamud",
  "license": "MIT",
  "packageManager": "bun@1.3.6",
  "dependencies": {
    "nan": "^2.17.0"
  },
  "devDependencies": {
    "prettier": "2.8.8",
    "tree-sitter-cli": "0.25.10"
  },
  "scripts": {
    "install": "node scripts/install.js",
    "test": "tree-sitter generate && tree-sitter test",
    "test:upstream-corpus": "bun scripts/check-upstream-corpus.js",
    "format": "prettier --write \"**/*.{js,json}\"",
    "generate": "tree-sitter generate",
    "sync:upstream-noir": "bun scripts/sync-upstream-noir.js"
  },
  "tree-sitter": [
    {
      "scope": "source.noir",
      "injection-regex": "noir",
      "file-types": [
        "nr"
      ]
    }
  ]
}
